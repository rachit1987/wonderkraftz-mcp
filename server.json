{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.rachit1987/wonderkraftz-mcp",
  "title": "Wonderkraftz - Premium Gifting Studio",
  "description": "Browse and shop Wonderkraftz premium gifts. Recommendations, cart, and checkout via AI.",
  "iconUrl": "https://raw.githubusercontent.com/rachit1987/wonderkraftz-mcp/main/logo.png",
  "websiteUrl": "https://wonderkraftz.in",
  "repository": {
    "url": "https://github.com/rachit1987/wonderkraftz-mcp",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "wonderkraftz-mcp",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "SHOPIFY_STORE_DOMAIN",
          "description": "Shopify store domain (e.g., your-store.myshopify.com)",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "SHOPIFY_STOREFRONT_ACCESS_TOKEN",
          "description": "Public Storefront API access token from the Shopify Headless channel",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
