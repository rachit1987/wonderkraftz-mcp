{
  "name": "wonderkraftz-mcp",
  "version": "1.0.0",
  "mcpName": "io.github.rachit1987/wonderkraftz-mcp",
  "description": "MCP server for Wonderkraftz - browse products, get recommendations, manage cart, and checkout via AI assistants",
  "type": "module",
  "bin": {
    "wonderkraftz-mcp": "./dist/index.js",
    "wonderkraftz-mcp-http": "./dist/http.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "shopify",
    "wonderkraftz",
    "gifting",
    "e-commerce",
    "ai",
    "model-context-protocol"
  ],
  "author": "Wonderkraftz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rachit1987/wonderkraftz-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
